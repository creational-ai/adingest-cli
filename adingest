@dataclass(frozen=True)
class TestDevice:
    """A caller-declared test device whose REVENUE rows are excluded server-side.

    Two fields: an operator-authored ``name`` (a human label — safe to render
    in logs/summaries) and the advertising ``id`` (idfa/idfv) matched against
    each revenue row. Only ``id`` is flattened onto the wire
    (``test_device_ids``); ``name`` stays caller-side and is used solely for the
    named roster the CLI renders when rows are dropped (counts only, never IDs).

    Frozen so a parsed roster is immutable once loaded. ``name`` may be ``""``
    for an entry that omitted its label (``_parse_test_devices`` warns rather
    than fails) — matching is keyed on ``id``, so a nameless entry still filters;
    the roster renders it as an unlabeled device rather than degrading silently.
    """
    name: str
    id: str


@dataclass(frozen=True)
class AdingestConfig:
    """Caller-side configuration; frozen so flag overrides go through ``replace``.

    Step 9 of core-cli-config-refactor: the legacy ``from_env`` classmethod and
    the cwd-coupled ``_load_env_client`` loader were removed in favor of the
    TOML-backed ``load_config(slug)`` pipeline (Step 3). The dataclass shape is
    unchanged — same nine fields (``test_devices`` added by
    core-test-device-exclusion), same defaults, still frozen — but the
    construction surface is now the loader, not env-var scraping.
    """
    url: str = "http://localhost:8000"
    token: str = ""
    apps: list[dict[str, Any]] = field(default_factory=list)
    lp_secret_key: str = ""
    lp_refresh_token: str = ""
    bq_project_id: str = ""
    bq_dataset: str = ""
    bq_sa_key_path: str = ""
    test_devices: list[TestDevice] = field(default_factory=list)


# --- TOML config loader (~/.adingest/<slug>/) ------------------------------
#
# These helpers compose into ``load_config(slug)`` (landed in a later step).
# Here we land only the lowest-level primitives — no CLI surface change yet.
#
# Pipeline order downstream callers will follow:
#   1. ``_read_toml_if_exists(home/'config.toml')`` — optional global defaults
#   2. ``_read_toml(home/<slug>/'config.toml')``    — required per-caller
#   3. ``_deep_merge(global, per_caller)``          — overlay per-caller on global
#   4. ``_interpolate_env_recursive(merged)``       — substitute ``${VAR}``
#   5. ``_to_adingest_config(interpolated)``        — translate to dataclass
#
# Step 1 lands steps 1, 3, and 4 (plus the no-op ``_read_toml_if_exists``);
# Steps 2-3 land the rest.

#: Operator-owned config home. Override with ``ADINGEST_HOME`` for tests / sandbox runs.
ADINGEST_HOME: Path = Path(os.environ.get("ADINGEST_HOME") or (Path.home() / ".adingest"))

#: ``${VAR}`` reference pattern. Matches POSIX-style uppercase env var names
#: (``A-Z``, digits, underscore; must start with letter or underscore). Only
#: scalar string values are scanned for substitutions; ints/bools/floats pass
#: through ``_interpolate_env_recursive`` untouched.
_ENV_PATTERN = re.compile(r"\$\{([A-Z_][A-Z0-9_]*)\}")


def _read_toml(path: Path) -> dict[str, Any]:
    """Parse a required TOML file via stdlib ``tomllib`` (binary mode).

    Caller is responsible for the missing-file case; this helper raises
    whatever ``open()`` raises if the file is absent (typically
    ``FileNotFoundError``). Use ``_read_toml_if_exists`` when the file is
    optional.

    Malformed TOML → ``click.ClickException`` naming the path + the
    underlying parser message, so operators see a one-line classified
    failure (e.g., ``Error: TOML parse error in ~/.adingest/hexario/config.toml:
    Expected '=' after a key in a key/value pair``) instead of a raw traceback.

    Binary mode (``'rb'``) is REQUIRED by ``tomllib.load`` — text mode raises
    ``TypeError`` per the stdlib contract.
    """
    try:
        with path.open("rb") as f:
            return tomllib.load(f)
    except tomllib.TOMLDecodeError as e:
        raise click.ClickException(f"TOML parse error in {path}: {e}") from None


def _read_toml_if_exists(path: Path) -> dict[str, Any]:
    """Parse a TOML file if it exists; return ``{}`` if absent.

    Used for optional global config (``~/.adingest/config.toml``) where
    the file's absence is a legitimate state (no global defaults set).
    A malformed file still raises (via ``_read_toml``) — missing != broken.
    """
    if not path.exists():
        return {}
    return _read_toml(path)


def _deep_merge(base: dict[str, Any], overlay: dict[str, Any]) -> dict[str, Any]:
    """Recursive dict overlay; leaf-level merge, arrays REPLACE wholesale.

    Per design decision D14: when ``overlay`` carries a value for a key
    that ``base`` also has, the overlay wins at the leaf. For nested
    dicts, recursion continues; for any non-dict leaf (including
    ``list``), the overlay value replaces the base value entirely. Arrays
    are NEVER concatenated — a per-caller ``[[apps]]`` block replaces the
    global one wholesale, not appended to it.

    The returned dict is a new top-level dict; nested dicts that come
    from ``base`` only (no overlay collision) are reused by reference,
    not deep-copied. Callers must not mutate the result if they intend to
    preserve the inputs.

    Examples::

        _deep_merge({"a": {"x": 1, "y": 2}}, {"a": {"x": 99}})
        # → {"a": {"x": 99, "y": 2}}

        _deep_merge({"apps": [{"id": "a"}]}, {"apps": [{"id": "b"}]})
        # → {"apps": [{"id": "b"}]}      # arrays REPLACE, not concatenate
    """
    merged: dict[str, Any] = dict(base)
    for key, overlay_value in overlay.items():
        base_value = merged.get(key)
        if isinstance(base_value, dict) and isinstance(overlay_value, dict):
            merged[key] = _deep_merge(base_value, overlay_value)
        else:
            merged[key] = overlay_value
    return merged


def _interpolate_env_recursive(value: Any) -> Any:
    """Substitute ``${VAR}`` references in string values from ``os.environ``.

    Walks dicts and lists recursively; only ``str`` leaves are scanned.
    Non-string leaves (``int``, ``bool``, ``float``, ``None``) pass
    through untouched — TOML integers and booleans are NOT coerced
    through string interpolation.

    Missing env var → ``click.ClickException`` naming the variable and
    pointing the operator at the two candidate sources (``.env`` file or
    shell environment). NEVER silent empty-string substitution: a typo'd
    ``${INGEST_API_TKOEN}`` must fail loudly at config-load time, not
    silently produce an empty Bearer token that the server rejects with
    an opaque 401.

    Multiple references in a single string are all substituted in one
    pass; partial substitution is not exposed — either every ``${VAR}``
    resolves or the whole string raises.
    """
    if isinstance(value, dict):
        return {k: _interpolate_env_recursive(v) for k, v in value.items()}
    if isinstance(value, list):
        return [_interpolate_env_recursive(item) for item in value]
    if isinstance(value, str):
        def _replace(match: re.Match[str]) -> str:
            var_name = match.group(1)
            env_value = os.environ.get(var_name)
            if env_value is None:
                raise click.ClickException(
                    f"missing env var ${{{var_name}}} referenced in TOML config "
                    f"(check ~/.adingest/<slug>/.env or your shell environment)"
                )
            return env_value
        return _ENV_PATTERN.sub(_replace, value)
    return value


def _parse_test_devices(raw: list[dict[str, Any]]) -> list[TestDevice]:
    """Translate ``[[exclusions.test_devices]]`` entries to ``TestDevice`` records.

    Each entry is a TOML table with a required ``id`` (the advertising
    identifier — idfa/idfv — matched server-side against revenue rows) and a
    recommended ``name`` (an operator-authored human label).

    Contract:

    * Missing ``id`` is a HARD ERROR — ``click.ClickException`` naming the
      offending entry. An entry that can't be matched on is a config mistake
      the operator must fix, not silently drop (a silently-dropped device
      would keep polluting BQ with the operator none the wiser).
    * Missing ``name`` is a SOFT WARNING (stderr) — the entry is kept with
      ``name=""``. Matching keys on ``id``, so a nameless entry still filters;
      the roster later renders it as an unlabeled device rather than failing
      the whole run over a cosmetic omission.

    This helper carries the only raise in the config-translation path so
    ``_to_adingest_config`` stays "structural only" — the fail-loud validation
    is isolated here.

    Args:
        raw: The ``exclusions.test_devices`` array from the merged TOML dict
            (each element a dict as produced by ``tomllib``). Empty/absent →
            empty list (no exclusions configured).

    Returns:
        A list of frozen ``TestDevice`` records, order-preserving.

    Raises:
        click.ClickException: an entry omits ``id`` (message names the entry).

    Examples::

        >>> _parse_test_devices([{"name": "Galaxy", "id": "495d..."}])
        [TestDevice(name='Galaxy', id='495d...')]
    """
    devices: list[TestDevice] = []
    for entry in raw:
        device_id = entry.get("id")
        if not device_id:
            raise click.ClickException(
                f"test_devices entry missing required 'id': {entry!r}"
            )
        name = entry.get("name")
        if not name:
            click.echo(
                f"warning: test_devices entry {device_id!r} has no 'name'; "
                "it will filter but render unlabeled in the roster",
                err=True,
            )
            name = ""
        devices.append(TestDevice(name=str(name), id=str(device_id)))
    return devices


def _to_adingest_config(merged: dict[str, Any]) -> AdingestConfig:
    """Translate a merged-and-interpolated TOML dict to a frozen ``AdingestConfig``.

    Pipeline position: runs AFTER ``_deep_merge`` (global + per-caller overlay)
    and AFTER ``_interpolate_env_recursive`` (``${VAR}`` substitution). This
    step is purely structural — TOML sections to dataclass fields — with one
    side-effect-free transform: ``~``-expansion on path-typed fields.

    Section-to-field map (per D14, the TOML schema mirrors wire-contract
    field names; no flat-to-nested translation)::

        TOML key                          AdingestConfig field
        ────────────────────────────────  ─────────────────────────
        [ingest_api].url                  url
        [ingest_api].token                token
        [levelplay].secret_key            lp_secret_key
        [levelplay].refresh_token         lp_refresh_token
        [bq].project_id                   bq_project_id
        [bq].dataset                      bq_dataset
        [bq].sa_key_path                  bq_sa_key_path  (expanduser applied)
        [[apps]]                          apps            (list pass-through)
        [[exclusions.test_devices]]       test_devices    (parsed → TestDevice)

    Path-typed fields: only ``bq_sa_key_path`` today. ``${VAR}`` interpolation
    happens BEFORE this step; ``~``-expansion happens AFTER, so a
    ``${HOME}``-interpolated path that still carries a literal ``~`` (e.g.,
    if an operator wrote ``"~${REGION_SLUG}/key.json"``) gets its leading
    ``~`` expanded too. The result is cast back to ``str`` to match the
    dataclass field type — no ``pathlib.Path`` leaks into the validated
    boundary, and no filesystem check (``.exists()``/``.resolve()``) is
    performed; existence enforcement is the responsibility of whichever
    consumer actually opens the file.

    Unknown TOML keys (top-level sections OR nested keys inside known
    sections) are SILENTLY IGNORED for forward-compatibility: an older CLI
    consuming a newer config.toml that declares a future ``[gateway]`` block
    must not crash. Missing fields are NOT enforced here either — the
    ``AdingestConfig`` dataclass carries safe defaults (empty strings, empty
    list), and wire-contract validation happens server-side per CLAUDE.md
    durable invariant #2 (stateless service; consumer owns config).

    ``[[apps]]`` is passed through verbatim — each app dict retains its
    nested ``ga4`` sub-dict (``app["ga4"] = {"measurement_id": ..., "api_secret": ...}``)
    as produced by ``tomllib``. The dataclass field type is
    ``list[dict[str, Any]]``; downstream consumers (``AdingestClient._build_body``)
    treat each app as an opaque dict per the wire contract.

    Examples::

        >>> _to_adingest_config({
        ...     "ingest_api": {"url": "https://api.creational.ai", "token": "t"},
        ...     "bq": {"sa_key_path": "~/.adingest/hexario/bq.json"},
        ... })  # doctest: +SKIP
        AdingestConfig(url='https://api.creational.ai', token='t',
                       bq_sa_key_path='/Users/<user>/.adingest/hexario/bq.json',
                       ...)
    """
    ingest_api = merged.get("ingest_api") or {}
    levelplay = merged.get("levelplay") or {}
    bq = merged.get("bq") or {}
    apps = merged.get("apps") or []
    exclusions = merged.get("exclusions") or {}
    test_devices = _parse_test_devices(exclusions.get("test_devices") or [])

    bq_sa_key_path_raw = bq.get("sa_key_path", "")
    bq_sa_key_path = (
        str(Path(bq_sa_key_path_raw).expanduser()) if bq_sa_key_path_raw else ""
    )

    return AdingestConfig(
        url=ingest_api.get("url", "http://localhost:8000"),
        token=ingest_api.get("token", ""),
        apps=list(apps),
        lp_secret_key=levelplay.get("secret_key", ""),
        lp_refresh_token=levelplay.get("refresh_token", ""),
        bq_project_id=bq.get("project_id", ""),
        bq_dataset=bq.get("dataset", ""),
        bq_sa_key_path=bq_sa_key_path,
        test_devices=test_devices,
    )


def load_config(slug: str, home: Path = ADINGEST_HOME) -> AdingestConfig:
    """Load and compose the caller-scoped ``AdingestConfig`` for ``slug``.

    Top-level orchestrator that wires Steps 1-2's primitives into the
    single entry point the rest of the CLI consumes. The pipeline is
    fully deterministic: no env-var reads occur outside ``${VAR}``
    interpolation, no filesystem walks beyond the two well-known TOML
    paths, no caching (callers cache at higher layers if needed).

    Pipeline (in order)::

        1. _read_toml_if_exists(home / "config.toml")       # global defaults (optional)
        2. _read_toml(home / slug / "config.toml")          # per-caller (REQUIRED)
        3. _deep_merge(global, per_caller)                  # per-caller wins at leaves
        4. _interpolate_env_recursive(merged)               # substitute ${VAR} from os.environ
        5. _to_adingest_config(interpolated)                # translate to frozen dataclass

    Ordering invariants (each test-pinned)::

        * Interpolation runs AFTER deep-merge: a per-caller override of a
          global ``${VAR}`` reference avoids the missing-var error if the
          per-caller value is a literal (no ``${...}``). This means an
          operator can shadow a globally-referenced secret without setting
          the env var the global value points at.
        * Path expansion runs AFTER interpolation: a global
          ``sa_key_path = "${HOME}/.adingest/<slug>/key.json"`` survives
          ``${HOME}`` substitution first, then any residual ``~`` would
          expand. (In practice ``${HOME}`` interpolation produces an
          absolute path so the expanduser pass is a no-op, but the order
          is what matters for the contract.)

    Missing per-caller ``config.toml`` is a HARD ERROR — the loader has
    no idea what caller the operator meant if the directory doesn't
    exist. The raised ``ClickException`` carries the exact bootstrap
    command so a copy-paste-from-error-message recovery works.

    Malformed TOML in either file is a HARD ERROR — propagated through
    ``_read_toml`` with the file path in the message.

    The optional ``home`` parameter exists for test injection (fixtures
    point at a tmp directory). Production callers omit it and the
    module-level ``ADINGEST_HOME`` is used.

    Args:
        slug: The caller's slug (e.g., ``"hexario"``); used to locate
            ``<home>/<slug>/config.toml``. NOT validated here — callers
            that take user input should call ``_validate_slug`` first
            (Step 4 lands the validator).
        home: Root of the caller config tree. Defaults to
            ``ADINGEST_HOME`` (``$ADINGEST_HOME`` env override or
            ``~/.adingest``).

    Returns:
        Frozen ``AdingestConfig`` with all fields populated from the
        merged-then-interpolated TOML. Unknown keys silently ignored;
        missing fields fall back to dataclass defaults.

    Raises:
        click.ClickException: per-caller ``config.toml`` absent (with
            bootstrap-command hint), or either file is malformed TOML,
            or a ``${VAR}`` reference has no matching env var.

    Examples::

        >>> load_config("hexario")  # doctest: +SKIP
        AdingestConfig(url='https://api.creational.ai', token='...', ...)
    """
    per_caller_path = home / slug / "config.toml"
    if not per_caller_path.exists():
        raise click.ClickException(
            f"project {slug} not initialized — no {per_caller_path}; "
            f"run `adingest init {slug}` first"
        )

    global_dict = _read_toml_if_exists(home / "config.toml")
    per_caller_dict = _read_toml(per_caller_path)
    merged = _deep_merge(global_dict, per_caller_dict)
    interpolated = _interpolate_env_recursive(merged)
    return _to_adingest_config(interpolated)


# --- Project selection: state.toml + atomic write + slug validation ---------
#
# Step 4 of core-cli-config-refactor. Adds three primitives layered on top of
# the Step 1-3 loader:
#
# * ``_atomic_write_text`` — POSIX-atomic file write via tmp + fsync +
#   ``os.replace`` + parent-dir fsync. Single source of truth for atomic
#   writes; reused by ``state.toml`` writes here and by the ``init``
#   template-scaffold writes.
# * ``_read_state_active`` / ``write_state_active`` — read/write the
#   ``~/.adingest/state.toml`` active-project pointer. Loud-failure on
#   malformed TOML; silent on absent file (cascade fallthrough — Step 5
#   composes this with ``$ADINGEST_PROJECT`` + ``--project`` flag).
# * ``_validate_slug`` — slug character/shape validation. Used by
#   ``_read_state_active`` (defensive on path-traversal attempts in
#   ``state.toml``'s ``active`` value), by ``adingest use <slug>``
#   (Step 6 — pre-write validation), and by ``adingest init <slug>``
#   (Step 7 — pre-bootstrap validation).
#
# Crash-durability contract: ``_atomic_write_text`` guarantees that a
# crash mid-write leaves the prior target file content intact (the
# rename via ``os.replace`` is POSIX-atomic). Parent-dir fsync is
# best-effort: on non-POSIX filesystems where it raises ``OSError``,
# durability degrades to file-content-only — file is still atomically
# replaced, but the directory entry may not survive a power loss.

# Slug shape: lowercase alphanumeric + interior hyphens. Must start AND
# end with [a-z0-9]. Single-char allowed ("a"); pure hyphens rejected.
# ``re.fullmatch`` (NOT ``re.match``) is required — without it,
# ``foo/bar`` would silently match the ``foo`` prefix and bypass the
# path-traversal defense.
_SLUG_PATTERN = re.compile(r"[a-z0-9](?:[a-z0-9-]*[a-z0-9])?")


def _validate_slug(slug: str) -> None:
    """Validate a project slug against the canonical shape contract.

    Slugs must match ``[a-z0-9](?:[a-z0-9-]*[a-z0-9])?`` — lowercase
    alphanumeric with interior hyphens; alphanumeric start AND end.
    Single-char slugs are allowed (``"a"``). Pure-hyphens, leading/trailing
    hyphens, uppercase letters, and path-separator characters are rejected.

    The full-string contract is enforced via ``re.fullmatch`` (NOT
    ``re.match``, which would silently match a ``foo/bar`` slug at the
    ``foo`` prefix and bypass the path-traversal defense).

    Raises:
        click.UsageError: When the slug is empty, the wrong shape, or
            contains characters outside the allowed set. The message
            names the slug AND the allowed pattern so the operator can
            self-correct.

    Examples:
        >>> _validate_slug("hexario")     # OK
        >>> _validate_slug("a-b-c")       # OK
        >>> _validate_slug("a")           # OK (single-char allowed)
        >>> _validate_slug("-a")          # raises UsageError
        >>> _validate_slug("a-")          # raises UsageError
        >>> _validate_slug("Hex")         # raises UsageError (uppercase)
        >>> _validate_slug("foo/bar")     # raises UsageError (path sep)
    """
    if not _SLUG_PATTERN.fullmatch(slug):
        raise click.UsageError(
            f"invalid slug {slug!r}; must match [a-z0-9-]+ "
            f"(lowercase letters/digits/hyphen; alphanumeric start+end)"
        )


def _atomic_write_text(target: Path, payload: str, home: Path) -> None:
    """Atomically write ``payload`` to ``target`` via tmp + fsync + rename.

    POSIX-atomic write sequence:

    1. Write ``payload`` to ``<target>.tmp`` (binary mode to avoid encoding ambiguity)
    2. ``os.fsync`` the tmp file's fd so the bytes hit disk
    3. ``os.replace(tmp, target)`` — atomic rename (POSIX guarantee)
    4. Open ``home`` directory with ``os.O_DIRECTORY``, ``os.fsync`` the
       dir fd so the rename itself is durable

    Crash mid-step 1 or 2: ``target`` retains its prior content; the
    ``.tmp`` file may linger but is orphaned (next write replaces it).
    Crash mid-step 3: rename is atomic — caller sees either the old or
    the new content, never a half-written file. Crash mid-step 4: file
    content is replaced but the directory entry may not survive a power
    loss (best-effort durability).

    Parent-dir fsync portability: on macOS/Linux, ``os.fsync`` on a
    directory fd is supported. On Windows or some non-POSIX filesystems,
    it raises ``OSError``; we swallow the error there — file content is
    still atomic-replaced, just not durably committed against power loss.

    Args:
        target: Destination path. Parent directory must already exist
            (caller's responsibility — usually via ``home.mkdir(parents=True,
            exist_ok=True)`` on the slug-scoped dir).
        payload: String content to write (UTF-8 encoded internally).
        home: Directory whose fd to fsync after the rename. Usually the
            parent of ``target`` (``target.parent``), but passed
            explicitly so callers can fsync the canonical home root even
            when writing nested files.
    """
    tmp = target.with_suffix(target.suffix + ".tmp")
    data = payload.encode("utf-8")

    # Step 1+2: write payload to tmp, fsync the file fd.
    fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
    try:
        os.write(fd, data)
        os.fsync(fd)
    finally:
        os.close(fd)

    # Step 3: atomic rename. After this point ``target`` has the new content.
    os.replace(tmp, target)

    # Step 4: parent-dir fsync (best-effort on non-POSIX FS).
    try:
        dir_fd = os.open(home, os.O_DIRECTORY)
        try:
            os.fsync(dir_fd)
        finally:
            os.close(dir_fd)
    except OSError:
        # Non-POSIX filesystem (e.g., Windows). File content is atomic,
        # but the directory entry may not survive a power loss. This is
        # the documented degraded-durability path.
        pass


def _read_state_active(home: Path) -> str | None:
    """Read ``home/state.toml`` and return the ``active`` slug (or None).

    Cascade semantics: this is the third tier of the project-selection
    cascade (after ``--project`` flag and ``$ADINGEST_PROJECT``). Returns
    ``None`` when ``state.toml`` is absent (cascade fallthrough); raises
    loudly on malformed TOML or invalid ``active`` value (R1 MED#1 fix —
    silent fallthrough on a corrupt state file would hide the corruption
    and let the cascade silently mis-route, which is worse than failing
    fast).

    Returns:
        The validated ``active`` slug as a str, or ``None`` when
        ``state.toml`` doesn't exist OR exists but lacks an ``active`` key.

    Raises:
        click.ClickException: When ``state.toml`` exists but is malformed
            TOML, or when ``active`` is present but isn't a string
            matching ``_validate_slug``. The message names the repair
            command (``adingest use <slug>``) so the operator can recover
            without manual file editing.
    """
    state_path = home / "state.toml"
    if not state_path.exists():
        return None

    try:
        with state_path.open("rb") as f:
            data = tomllib.load(f)
    except tomllib.TOMLDecodeError as e:
        raise click.ClickException(
            f"state.toml malformed at {state_path}: {e}; "
            f"re-run `adingest use <slug>` to repair"
        ) from e

    active = data.get("active")
    if active is None:
        return None

    if not isinstance(active, str):
        raise click.ClickException(
            f"state.toml has invalid `active` value {active!r} at {state_path}; "
            f"expected a string slug; re-run `adingest use <slug>` to repair"
        )

    # Validate slug shape — defense against path-traversal injection via
    # state.toml (e.g., ``active = "../etc"``).
    try:
        _validate_slug(active)
    except click.UsageError as e:
        raise click.ClickException(
            f"state.toml has invalid slug {active!r} at {state_path}: {e.message}; "
            f"re-run `adingest use <slug>` to repair"
        ) from e

    return active


def write_state_active(slug: str, home: Path = ADINGEST_HOME) -> None:
    """Atomically write the active-project pointer to ``home/state.toml``.

    Creates ``home`` if it doesn't already exist (covers the bootstrap
    path where ``adingest init <slug>`` materializes ``~/.adingest/`` for
    the first time). Slug is NOT validated here — callers (``use`` /
    ``init``) validate before calling so the operator-facing UsageError
    fires earlier in the command body.

    The TOML payload uses literal quoted-string syntax (``active = "..."``)
    rather than ``tomli_w.dumps`` for the trivial single-key case —
    keeps Step 4 dependency-free (``tomli_w`` is needed later in Step 11
    for the migration-side global TOML writes).

    Args:
        slug: Validated project slug (alphanumeric + interior hyphens).
        home: Project home dir. Defaults to ``ADINGEST_HOME`` module
            constant; tests inject a ``tmp_path``.
    """
    home.mkdir(parents=True, exist_ok=True)
    _atomic_write_text(home / "state.toml", f'active = "{slug}"\n', home)


# --- Selection cascade + cache + per-caller env sourcing --------------------
#
# Step 5 of core-cli-config-refactor. Layers the 4-tier project-selection
# cascade on top of Step 4's ``_read_state_active``, with a read-once-at-startup
# module-level cache so a long-running CLI invocation never re-resolves the
# active project mid-flight (Goal 3 concurrency contract: an in-flight
# ``ingest`` started against ``hexario`` stays on ``hexario`` even if a
# concurrent shell runs ``adingest use staging``).
#
# Cascade order (highest precedence first):
#   1. ``--project <slug>`` flag (``explicit`` argument)
#   2. ``$ADINGEST_PROJECT`` env-var
#   3. ``~/.adingest/state.toml`` → ``active``
#   4. Loud failure (no fallback)
#
# Cache contract per R1 MED#2:
#   * First call (with or without ``explicit``) populates the cache; subsequent
#     calls return the cached slug REGARDLESS of ``explicit`` / env / state.toml
#     mutations that happen later in the process lifetime.
#   * Production CLI invocations are one-command-per-process so the cache is
#     always cold when ``_build_config`` (Step 9) is first entered; the cache
#     only matters when (a) the same process runs multiple commands (tests via
#     ``CliRunner``) or (b) a long-running call re-resolves mid-flight.
#   * ``_invalidate_cache_for_tests()`` is the test-only escape hatch; Step 14
#     lands the autouse ``_reset_cli_cache`` fixture that calls it between tests.

#: Module-level cache for the resolved active-project slug. ``None`` means
#: "not yet resolved this process"; once set, ``resolve_active_project``
#: returns the cached value without re-reading state.toml or env.
_ACTIVE_PROJECT_CACHE: str | None = None


def _invalidate_cache_for_tests() -> None:
    """Reset ``_ACTIVE_PROJECT_CACHE`` to ``None``.

    Test-only escape hatch per D12. Production code MUST NOT call this —
    the cache contract is "resolve once, never re-resolve". Tests that
    exercise the cascade in series against the same process need to
    reset the cache between scenarios; Step 14 lands the autouse
    ``_reset_cli_cache`` fixture that calls this helper between tests.
    """
    global _ACTIVE_PROJECT_CACHE
    _ACTIVE_PROJECT_CACHE = None


def resolve_active_project(
    explicit: str | None = None, home: Path = ADINGEST_HOME
) -> str:
    """Resolve the active-project slug via the 4-tier cascade.

    Cascade order (highest precedence first):

    1. ``explicit`` — the ``--project <slug>`` flag value (typically passed
       through from Click command bodies)
    2. ``$ADINGEST_PROJECT`` — environment variable
    3. ``~/.adingest/state.toml`` → ``active`` — operator-set persistent default
    4. Loud failure — no fallback; the cascade is exhaustive

    Cache contract per R1 MED#2:
        * First call populates ``_ACTIVE_PROJECT_CACHE`` from whichever
          tier wins; subsequent calls return the cached slug.
        * ``explicit`` is checked FIRST (before cache short-circuit) so the
          first call with a flag sets the cache to the flag value. BUT if
          the cache is already set to something else, ``explicit`` is
          IGNORED silently — production never re-resolves, and a second
          flag-bearing call in the same process indicates either a test
          (which should ``_invalidate_cache_for_tests`` first) or a bug.
        * Env-var and state.toml reads also seed the cache on first call;
          subsequent mutations to either source are invisible.

    Args:
        explicit: The ``--project`` flag value, or ``None`` when the flag
            isn't supplied. Validated via ``_validate_slug`` if non-None.
        home: Project home dir. Defaults to ``ADINGEST_HOME`` module
            constant; tests inject a ``tmp_path``.

    Returns:
        The resolved (or cached) project slug.

    Raises:
        click.UsageError: When ``explicit`` or ``$ADINGEST_PROJECT`` fails
            slug validation (defensive against operator typos).
        click.ClickException: When all four tiers are absent. The message
            names both recovery paths (``adingest use <slug>`` to set a
            default, or ``--project <slug>`` to override per-invocation)
            and points at ``adingest projects`` for the list of configured
            slugs.
    """
    global _ACTIVE_PROJECT_CACHE

    # R1 MED#2 contract: check ``explicit`` FIRST (before cache short-circuit).
    # If cache is empty AND explicit is provided, the explicit wins and
    # populates the cache. If cache is set AND explicit is provided, the
    # explicit is IGNORED silently — production never re-resolves.
    if _ACTIVE_PROJECT_CACHE is not None:
        return _ACTIVE_PROJECT_CACHE

    if explicit is not None:
        _validate_slug(explicit)
        _ACTIVE_PROJECT_CACHE = explicit
        return explicit

    env_value = os.environ.get("ADINGEST_PROJECT")
    if env_value:
        # Validate slug — guards against typos / shell-injection. Loud
        # failure surfaces an operator-readable UsageError naming the
        # offending env-var-derived slug.
        _validate_slug(env_value)
        _ACTIVE_PROJECT_CACHE = env_value
        return env_value

    state_value = _read_state_active(home)
    if state_value is not None:
        _ACTIVE_PROJECT_CACHE = state_value
        return state_value

    raise click.ClickException(
        "no active project; run `adingest use <slug>` or pass "
        "--project <slug> (see `adingest projects` for the list)"
    )


def _source_project_env(slug: str, home: Path = ADINGEST_HOME) -> None:
    """Source ``~/.adingest/<slug>/.env`` into ``os.environ`` (setdefault).

    Loads per-caller secrets so the ``${VAR}`` references in the per-caller
    ``config.toml`` resolve cleanly during ``_interpolate_env_recursive``.
    ``os.environ.setdefault`` semantics: shell env wins over the file (an
    operator-set ``LP_SECRET_KEY=...`` in the shell takes precedence over the
    file value).

    Parser shape mirrors ``_load_env_client`` (which is removed in Step 9):
    ``KEY=value`` lines, ``#`` comments, blank lines skipped, surrounding
    quotes stripped, malformed lines silently skipped.

    Security: emits a stderr warning (NOT an error — operator can still
    proceed) if the ``.env`` file's mode is looser than 0600. Tightening
    is the operator's responsibility; we don't mutate the mode silently
    because that could mask a deliberate ACL the operator chose to set.

    Args:
        slug: Validated project slug. Caller is responsible for slug
            validation (typically via ``resolve_active_project`` which
            validates each cascade tier).
        home: Project home dir. Defaults to ``ADINGEST_HOME`` module
            constant; tests inject a ``tmp_path``.

    Side effects:
        Mutates ``os.environ`` via ``setdefault`` for each parsed line.
        Emits a stderr warning if file mode is looser than 0600.
    """
    env_path = home / slug / ".env"
    if not env_path.exists():
        return

    # Mode check: warn (not error) if looser than 0600.
    # ``stat.S_IMODE`` masks off the file-type bits, leaving only the
    # permission bits. We compare against ``0o600`` directly — any group
    # or world bit set means the secrets file is over-permissive.
    mode = env_path.stat().st_mode & 0o777
    if mode & 0o077:
        click.echo(
            f"warning: {env_path} has mode {oct(mode)}; "
            f"recommend tightening to 0600 (chmod 600 {env_path})",
            err=True,
        )

    for raw in env_path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, value = line.partition("=")
        # Strip surrounding quotes (single or double) — matches the
        # ``_load_env_client`` shape and the operator-facing convention
        # of quoting values that contain special characters.
        os.environ.setdefault(key.strip(), value.strip().strip('"').strip("'"))


# --- HTTP client ------------------------------------------------------------


class AdingestClient:
    """HTTP client speaking the ad-ingest wire contract (``/v1/`` + ``/v1/jobs/{id}``)."""

    def __init__(
        self, config: AdingestConfig, transport: httpx.BaseTransport | None = None
    ) -> None:
        self.config = config
        self._client = httpx.Client(
            base_url=config.url,
            headers={"Authorization": f"Bearer {config.token}"},
            timeout=30.0,
            transport=transport,
        )

    def post_ingest(
        self, event_date: str, source: str, apps: list[dict[str, Any]]
    ) -> dict[str, Any]:
        return self._request("POST", "/v1/", json=self._build_body(event_date, source, apps))

    def post_fetch_only(
        self, event_date: str, source: str, apps: list[dict[str, Any]]
    ) -> dict[str, Any]:
        """POST a ``fetch_only=true`` ingest — no ``destinations`` block, zero writes.

        The body carries the same sources/creds + apps/match config as a normal
        ingest but sets ``fetch_only: true`` and omits ``destinations`` entirely,
        so no BQ SA key is read and no destination creds are required (the
        zero-cred validation win). The service runs the identical adapter fetch →
        validation → match-remap path and stops before every sink.
        """
        return self._request(
            "POST", "/v1/", json=self._build_fetch_only_body(event_date, source, apps)
        )

    def get_job(self, job_id: str) -> dict[str, Any]:
        return self._request("GET", f"/v1/jobs/{job_id}")

    def _request(self, method: str, path: str, **kw: Any) -> dict[str, Any]:
        """Send one HTTP request; convert httpx errors to click.ClickException so
        operators see a one-line classified failure (e.g.,
        ``Error: HTTP 422 POST /v1/ — invalid event_date``) instead of a raw
        Python traceback."""
        try:
            resp = self._client.request(method, path, **kw)
            resp.raise_for_status()
        except httpx.HTTPStatusError as e:
            detail = ""
            try:
                body = e.response.json()
                detail = body.get("detail") or body.get("title") or ""
            except (json.JSONDecodeError, ValueError):
                detail = e.response.text[:200].strip()
            msg = f"HTTP {e.response.status_code} {method} {path}"
            raise click.ClickException(f"{msg} — {detail}" if detail else msg) from None
        except httpx.RequestError as e:
            raise click.ClickException(
                f"network error {type(e).__name__}: {e} (is the service running at {self.config.url}?)"
            ) from None
        return resp.json()  # type: ignore[no-any-return]

    def poll_until_terminal(
        self, job_id: str, interval: float = 2.0, max_wait: float = 120.0
    ) -> dict[str, Any]:
        deadline = time.monotonic() + max_wait
        while True:
            body = self.get_job(job_id)
            if body.get("status") in ("complete", "partial", "failed"):
                return body
            if time.monotonic() >= deadline:
                return body
            time.sleep(interval)

    def _build_sources_block(self, source: str) -> dict[str, Any]:
        """Assemble the ``sources`` wire block for ``source`` (creds from config).

        Shared by ``_build_body`` (normal ingest) and ``_build_fetch_only_body``
        so the source→creds mapping lives in one place; the two callers differ
        only in whether they append a ``destinations`` block.
        """
        if source == "stub":
            return {"stub_ok": {"value": "stub"}}
        if source == "levelplay":
            return {"levelplay": {
                "secret_key": self.config.lp_secret_key,
                "refresh_token": self.config.lp_refresh_token,
            }}
        raise click.UsageError(f"Unknown source: {source!r} (expected 'levelplay' or 'stub')")

    def _build_body(
        self, event_date: str, source: str, apps: list[dict[str, Any]]
    ) -> dict[str, Any]:
        sa_key: dict[str, Any] = {}
        if self.config.bq_sa_key_path and Path(self.config.bq_sa_key_path).exists():
            sa_key = json.loads(Path(self.config.bq_sa_key_path).read_text())
        body: dict[str, Any] = {
            "event_date": event_date,
            "apps": apps,
            "sources": self._build_sources_block(source),
            "destinations": {"bigquery": {
                "project_id": self.config.bq_project_id,
                "dataset": self.config.bq_dataset,
                "sa_key": sa_key,
            }},
        }
        if self.config.test_devices:
            body["test_device_ids"] = [d.id for d in self.config.test_devices]
        return body

    def _build_fetch_only_body(
        self, event_date: str, source: str, apps: list[dict[str, Any]]
    ) -> dict[str, Any]:
        """Build the fetch-only request body: ``fetch_only: true``, NO ``destinations``.

        Omitting ``destinations`` is the zero-cred contract — no BQ SA key is
        read (``_build_body`` reads it; this path never touches it). The server's
        ``check_destinations_present`` validator accepts a missing
        ``destinations`` iff ``fetch_only`` is true.
        """
        body: dict[str, Any] = {
            "event_date": event_date,
            "apps": apps,
            "sources": self._build_sources_block(source),
            "fetch_only": True,
        }
        if self.config.test_devices:
            body["test_device_ids"] = [d.id for d in self.config.test_devices]
        return body


# --- Verdict classifier -----------------------------------------------------


class VerdictClassifier:
    """Maps per-source counters to ordered verdict slugs (precedence-ranked).

    Precedence: tier ``🚨 > ⚠️ > ✅``; within a tier, the lower table index wins.
    ``classify`` returns the full ordered triggered list (pre-precedence) so
    ``--json`` consumers see every match; rendering picks index 0.
    """

    # Table order encodes within-tier precedence. (slug, emoji).
    VERDICTS: tuple[tuple[str, str], ...] = (
        ("healthy-fresh", "✅"),
        ("healthy-dedup", "✅"),
        ("partial-dedup", "⚠️"),
        ("empty-upstream", "🚨"),
        ("invalid-heavy", "🚨"),
        ("writer-orphan-heavy", "🚨"),
        ("ga4-orphan-heavy", "🚨"),
        ("silent-drop", "🚨"),
        ("fetch-only", "✅"),  # index-stable append (core-fetch-only Step 6)
    )
    TIER_RANK: ClassVar[dict[str, int]] = {"🚨": 0, "⚠️": 1, "✅": 2}

    @classmethod
    def classify(cls, source: dict[str, Any], fetch_only: bool = False) -> list[str]:
        f = int(source.get("rows_fetched", 0))
        inv = int(source.get("rows_invalid", 0))
        if fetch_only:
            # Mode-aware: a fetch-only job NEVER touches the writer / dedup / GA4,
            # so only the two PRE-SINK conditions can fire — ``empty-upstream``
            # (f==0) and ``invalid-heavy`` (inv > 5% of f). The writer/GA4/dedup
            # triggers (``silent-drop`` chief among them) are structurally
            # impossible here and must not be evaluated: evaluating ``silent-drop``
            # (i < f - inv - d, with i==d==0) fires on every healthy fetch-only
            # source — the exact false positive this branch kills. Neither
            # pre-sink trigger firing → the healthy ``fetch-only`` verdict.
            fo: list[int] = []
            if f == 0:
                fo.append(3)  # empty-upstream 🚨 (guarded on f==0; inv can't co-fire)
            if f > 0 and inv > 0.05 * f:
                fo.append(4)  # invalid-heavy 🚨
            if not fo:
                fo.append(8)  # fetch-only ✅ (healthy: rows fetched, invalid within tolerance)
            fo.sort(key=lambda t: (cls.TIER_RANK[cls.VERDICTS[t][1]], t))
            return [cls.VERDICTS[t][0] for t in fo]
        d = int(source.get("rows_skipped_dedup", 0))
        i = int(source.get("rows_inserted", 0))
        o = int(source.get("rows_inserted_orphan", 0))
        ga = int(source.get("ga4_events_attempted", 0))
        go = int(source.get("ga4_events_skipped_orphan", 0))
        # Engine-seam test-device drops (core-test-device-exclusion). These rows
        # are fetched-then-dropped BEFORE the writer, so the row-balance identity
        # is ``f == inv + x + d + i`` (fetched = invalid + test-device + dedup +
        # inserted). All three ``(f - inv)``-keyed triggers below MUST subtract
        # ``x`` or a fire touching a test device mis-classifies: at ``x > 0`` the
        # raw ``i == f - inv`` never holds (kept rows fall short by ``x``), so
        # BOTH healthy triggers go silent (blank verdict) AND ``silent-drop``
        # false-fires on ``i < f - inv - d``. Subtracting ``x`` restores the
        # healthy verdict. At ``x == 0`` every trigger reduces to its prior form.
        x = int(source.get("rows_skipped_test_device", 0))
        triggers: list[int] = []
        if f > 0 and i == (f - inv - x) and d == 0:
            triggers.append(0)
        if f > 0 and d == (f - inv - x) and i == 0:
            triggers.append(1)
        if f > 0 and i > 0 and d > 0:
            triggers.append(2)
        if f == 0:
            triggers.append(3)
        if f > 0 and inv > 0.05 * f:
            triggers.append(4)
        if i > 0 and (o / i) > 0.5:
            triggers.append(5)
        if ga > 0 and (go / ga) > 0.5:
            triggers.append(6)
        if i < (f - inv - x - d):
            triggers.append(7)
        triggers.sort(key=lambda t: (cls.TIER_RANK[cls.VERDICTS[t][1]], t))
        return [cls.VERDICTS[t][0] for t in triggers]

    @classmethod
    def display(cls, slugs: list[str]) -> str:
        if not slugs:
            return ""
        emoji = next(em for slug, em in cls.VERDICTS if slug == slugs[0])
        return f"{emoji} {slugs[0]}"


def _per_app_counters(source: dict[str, Any], app: dict[str, Any]) -> dict[str, Any]:
    """Build a SCOPE-CORRECT per-(platform, app_id) counter dict for classification.

    The engine's ``by_app_platform`` rollup carries only writer-boundary counters
    (``rows_skipped_dedup`` / ``rows_inserted`` / ``rows_inserted_orphan``) — there is
    NO per-app ``rows_fetched`` or ``rows_invalid`` because unmatched rows (counted in
    the source's ``rows_invalid``) belong to NO app. Naively classifying
    ``{**source, **app}`` lets each app inherit the SOURCE's total ``rows_fetched`` /
    ``rows_invalid`` / GA4 counters while carrying only its own writer slice, so
    ``silent-drop`` (``i < f - inv - d``) fires falsely on every app of a multi-app
    source — the source total is charged against one app's rows. (Single-app sources
    masked this: source-fetched == that app's fetched.)

    Scope-correct model: per-app ``rows_fetched`` is the rows that MATCHED this app =
    ``rows_inserted + rows_skipped_dedup`` (orphan is a subset of inserted, not
    additive); per-app ``rows_invalid`` and GA4 counters are 0 (source-level concepts
    with no per-app breakdown). This makes every per-app verdict meaningful
    (healthy-fresh / healthy-dedup / partial-dedup / writer-orphan-heavy) and makes
    ``silent-drop`` structurally impossible at app scope (``i < (i+d) - 0 - d`` == ``i < i``).
    """
    d = int(app.get("rows_skipped_dedup", 0))
    i = int(app.get("rows_inserted", 0))
    o = int(app.get("rows_inserted_orphan", 0))
    return {
        "rows_fetched": i + d,  # matched rows for this app (unmatched rows have no app)
        "rows_invalid": 0,
        "rows_skipped_dedup": d,
        "rows_inserted": i,
        "rows_inserted_orphan": o,
        "ga4_events_attempted": 0,  # no per-app GA4 breakdown — source-scope only
        "ga4_events_skipped_orphan": 0,
    }


# --- Renderer ---------------------------------------------------------------


def _format_uid_pct(inserted: int, orphan: int) -> str:
    """Render ``%uid``: ``—`` when zero inserted; ``ERR`` on orphan>inserted invariant violation."""
    if inserted == 0:
        return "—"
    if orphan > inserted:
        return "ERR"
    return f"{((inserted - orphan) / inserted) * 100:.1f}%"


class TableRenderer:
    """Renders a job-status response as verdict-annotated rich table(s)."""

    COLS = ("Key", "fetched", "invalid", "skipped_dedup", "skipped_test",
            "inserted", "orphan", "%uid", "verdict")

    def __init__(self, console: Console | None = None) -> None:
        self.console = console or Console()

    def render(
        self, response: dict[str, Any], device_names: list[str] | None = None
    ) -> None:
        job_id = response.get("job_id", "?")
        status = response.get("status", "?")
        dur = self._duration(response)
        self.console.print(f"Job {job_id}  status={status}  {dur}".rstrip())
        for source_name, source in response.get("sources", {}).items():
            self._render_source(source_name, source)
        self._maybe_render_roster(response, device_names)
        for err in response.get("errors") or []:
            self.console.print(f"[red]error:[/red] {err}")

    def _render_source(self, source_name: str, source: dict[str, Any]) -> None:
        self.console.print(f"Source: {source_name}")
        by_app = source.get("by_app_platform", {})
        table = Table(show_header=True, header_style="bold")
        for col in self.COLS:
            table.add_column(col)
        # Single-app collapse: omit per-app rows when only one app present.
        if len(by_app) > 1:
            for key, app in by_app.items():
                ins = int(app.get("rows_inserted", 0))
                orp = int(app.get("rows_inserted_orphan", 0))
                slugs = VerdictClassifier.classify(_per_app_counters(source, app))
                # Per-app rows carry no engine-seam skip breakdown (skipped_test
                # is a source-level counter — Open Question 4 defers per-device
                # attribution), so the extra column renders ``⋯`` like the other
                # writer-boundary counters. The 4th ``⋯`` keeps COLS-aligned with
                # the source-total row's ``skipped_test`` value below.
                table.add_row(key, "⋯", "⋯", "⋯", "⋯", str(ins), str(orp),
                              _format_uid_pct(ins, orp), VerdictClassifier.display(slugs))
            table.add_section()
        ins = int(source.get("rows_inserted", 0))
        orp = int(source.get("rows_inserted_orphan", 0))
        slugs = VerdictClassifier.classify(source)
        table.add_row(
            "source total",
            str(source.get("rows_fetched", 0)),
            str(source.get("rows_invalid", 0)),
            str(source.get("rows_skipped_dedup", 0)),
            str(source.get("rows_skipped_test_device", 0)),
            str(ins), str(orp),
            _format_uid_pct(ins, orp),
            VerdictClassifier.display(slugs),
        )
        self.console.print(table)
        self.console.print(
            f"GA4: attempted={source.get('ga4_events_attempted', 0)}  "
            f"sent={source.get('ga4_events_sent', 0)}  "
            f"skipped_orphan={source.get('ga4_events_skipped_orphan', 0)}  "
            f"failed={source.get('ga4_events_failed', 0)}"
        )

    def render_fetch_only(
        self, response: dict[str, Any], device_names: list[str] | None = None
    ) -> None:
        """Render a fetch-only job: per-source counters summary + a
        per-(platform, app_id) row breakdown derived CLI-side from the rows.

        Fetch-only never touches the writer or GA4, so the writer-boundary
        columns (``skipped_dedup`` / ``inserted`` / ``orphan`` / ``%uid``) and
        the ``GA4:`` summary line are omitted entirely rather than rendered as
        misleading zeros. The per-app breakdown is counted from
        ``rows_by_source`` — the job's ``by_app_platform`` counter is a
        writer-boundary rollup and is empty on fetch-only jobs. No raw rows are
        dumped; only the aggregated counts are shown.
        """
        job_id = response.get("job_id", "?")
        status = response.get("status", "?")
        dur = self._duration(response)
        self.console.print(f"Job {job_id}  status={status}  {dur}".rstrip())
        rows_by_source = response.get("rows_by_source") or {}
        for source_name, source in response.get("sources", {}).items():
            self._render_fetch_only_source(
                source_name, source, rows_by_source.get(source_name) or []
            )
        self._maybe_render_roster(response, device_names)
        for err in response.get("errors") or []:
            self.console.print(f"[red]error:[/red] {err}")

    def _render_fetch_only_source(
        self, source_name: str, source: dict[str, Any], rows: list[dict[str, Any]]
    ) -> None:
        # Mode-aware verdict for the fetch-only human path. Step 5 chose the
        # dedicated ``render_fetch_only`` bypass over reusing ``_render_source``,
        # so this single call is the entire render-side thread-through for
        # fetch-only: ``fetch_only=True`` yields the mode-aware ``fetch-only``
        # verdict (never the spurious ``silent-drop``).
        slugs = VerdictClassifier.classify(source, fetch_only=True)
        self.console.print(
            f"Source: {source_name}  "
            f"fetched={source.get('rows_fetched', 0)}  "
            f"invalid={source.get('rows_invalid', 0)}  "
            f"skipped_test={source.get('rows_skipped_test_device', 0)}  "
            f"verdict={VerdictClassifier.display(slugs)}".rstrip()
        )
        breakdown = Counter(
            (str(r.get("platform", "")), str(r.get("app_id", ""))) for r in rows
        )
        table = Table(show_header=True, header_style="bold")
        for col in ("platform", "app_id", "rows"):
            table.add_column(col)
        for (platform, app_id), count in sorted(breakdown.items()):
            table.add_row(platform, app_id, str(count))
        self.console.print(table)

    def _maybe_render_roster(
        self, response: dict[str, Any], device_names: list[str] | None
    ) -> None:
        """Render the configured test-device roster ONCE at job scope, but only
        when the job actually dropped ≥1 test-device row.

        Gating on the summed ``rows_skipped_test_device`` (not merely on a
        non-empty config) means a stale/perished ID that stopped matching shows
        no roster — the absent roster is itself the operator's signal that the
        list matched nothing (design Open Question 1: the guard rests on the
        counter being watched). Called after the per-source loop in BOTH
        ``render`` and ``render_fetch_only`` so a multi-source response renders
        the global-config roster once, never per-source.
        """
        if not device_names:
            return
        total_skipped = sum(
            int(s.get("rows_skipped_test_device", 0))
            for s in response.get("sources", {}).values()
        )
        if total_skipped > 0:
            self._render_roster(device_names)

    def _render_roster(self, device_names: list[str]) -> None:
        """Print the configured test-device roster BY NAME — never raw IDs.

        Logs the operator-authored ``name`` labels (PII-safe) and the configured
        count only; the advertising IDs (``idfa``/``idfv``) never reach any
        rendered surface. An entry configured without a ``name`` (``name=""``,
        the soft-warn path in ``_parse_test_devices``) renders as ``(unnamed)``
        so the roster length stays honest. Per-device match attribution is
        deferred (design Open Question 4) — this is the "which devices are
        configured" roster; the scalar ``skipped_test`` counter is the "how
        much" surface.
        """
        labels = [name if name else "(unnamed)" for name in device_names]
        self.console.print(
            f"Test-device exclusions ({len(device_names)} configured): "
            + ", ".join(labels)
        )

    @staticmethod
    def _duration(response: dict[str, Any]) -> str:
        started, completed = response.get("started_at"), response.get("completed_at")
        if not started or not completed:
            return ""
        try:
            t0 = datetime.fromisoformat(started.replace("Z", "+00:00"))
            t1 = datetime.fromisoformat(completed.replace("Z", "+00:00"))
            return f"{(t1 - t0).total_seconds():.1f}s"
        except (ValueError, AttributeError):
            return ""


def _merge_verdicts_into_response(response: dict[str, Any]) -> dict[str, Any]:
    """Return ``response`` with ``verdicts: [...]`` injected at every row scope."""
    out: dict[str, Any] = json.loads(json.dumps(response))  # deep copy via JSON round-trip
    # Top-level ``fetch_only`` picks the mode-aware trigger set. This only sees
    # the flag because ``_emit_fetch_only`` merges BEFORE popping ``fetch_only``
    # from the envelope (the Step 4 ordering interlock); popping first would make
    # this classifier mode-blind and resurrect ``silent-drop`` on the stderr
    # ``2>counters.json`` channel. (fetch-only jobs carry an empty
    # ``by_app_platform``, so the per-app loop is a no-op for them — threading the
    # flag there is harmless and keeps the two paths symmetric.)
    fetch_only = bool(out.get("fetch_only"))
    for source in out.get("sources", {}).values():
        source["verdicts"] = VerdictClassifier.classify(source, fetch_only=fetch_only)
        for app in source.get("by_app_platform", {}).values():
            app["verdicts"] = VerdictClassifier.classify(
                _per_app_counters(source, app), fetch_only=fetch_only
            )
    return out


# --- Upgrade flow -----------------------------------------------------------


#: Verdict slug emitted by :meth:`UpgradeFlow.compute_verdict` — one of four
#: branches. Only ``"older-required"`` proceeds past step 4 of the 9-step flow;
#: the other three exit cleanly at step 4 with an informational message.
UpgradeVerdict = Literal["equal", "local-newer", "older-compatible", "older-required"]


@dataclass(frozen=True)
class CliVersionManifest:
    """Frozen mirror of the service's ``CliVersionManifest`` Pydantic model.

    The CLI is a PEP 723 single-file script with no Pydantic dep (would bloat
    the install gesture). All six fields are ``str`` per the wire contract
    (see ``src/ad_ingest/cli_version.py:CliVersionManifest`` and core-deploy
    design §2 Analysis #1). ``parse`` validates the field set at runtime — a
    missing or unexpected field surfaces as a :class:`click.ClickException`
    so the operator sees a one-line classified failure, not a Python
    ``KeyError`` traceback.
    """

    product: str
    server_version: str
    cli_recommended: str
    cli_min_compatible: str
    download_url: str
    cli_sha256: str

    @classmethod
    def parse(cls, body: dict[str, Any]) -> CliVersionManifest:
        """Validate ``body`` carries exactly the six declared ``str`` fields.

        Raises :class:`click.ClickException` on missing or non-string fields
        — operators see a classified failure rather than a Python ``KeyError``
        or ``TypeError`` traceback.
        """
        required = ("product", "server_version", "cli_recommended",
                    "cli_min_compatible", "download_url", "cli_sha256")
        missing = [k for k in required if k not in body]
        if missing:
            raise click.ClickException(
                f"manifest missing required field(s): {', '.join(missing)}"
            )
        for k in required:
            if not isinstance(body[k], str):
                raise click.ClickException(
                    f"manifest field {k!r} expected str, got {type(body[k]).__name__}"
                )
        return cls(
            product=body["product"],
            server_version=body["server_version"],
            cli_recommended=body["cli_recommended"],
            cli_min_compatible=body["cli_min_compatible"],
            download_url=body["download_url"],
            cli_sha256=body["cli_sha256"],
        )


def _version_tuple(v: str) -> tuple[int, ...]:
    """Parse a dotted X.Y.Z version into a comparable int-tuple.

    ``"0.0.0-dev"`` strips the ``-dev`` suffix → ``(0, 0, 0)``. The placeholder
    must always compare ``older-required`` against any real release because
    ``-dev`` is the dev-tree seed Phase 1a bakes into the installed copy. Any
    non-numeric component after stripping ``-dev`` raises
    :class:`click.ClickException` so a malformed manifest never silently
    compares as "equal" against an unexpected string.
    """
    bare = v.split("-", 1)[0]  # strip "-dev" / "-rc1" / etc.
    parts = bare.split(".")
    try:
        return tuple(int(p) for p in parts)
    except ValueError as e:
        raise click.ClickException(
            f"unparseable version {v!r}: expected dotted integers (X.Y.Z), got {e}"
        ) from None


class UpgradeFlow:
    """Encapsulates the 9-step universal upgrade flow (core-deploy design §2).

    Driven by :func:`upgrade` (Click subcommand). Steps:

    1. Resolve target server (URL from config — env or ``--url`` override)
    2. ``GET /v1/cli/version`` with Bearer → parse into
       :class:`CliVersionManifest`
    3. Verify ``manifest.product`` matches the bundled :data:`PRODUCT` literal;
       mismatch → ABORT (operator pointed at the wrong product's server)
    4. Compute verdict by comparing local :data:`__version__` to
       ``manifest.cli_recommended`` (four branches; see :class:`UpgradeVerdict`)
    5. (older-required only) ``GET manifest.download_url`` over HTTPS
       (commit-SHA-pinned; no Bearer — GitHub raw is public)
    6. (older-required only) Compute sha256 of fetched body; compare to
       ``manifest.cli_sha256``; mismatch → ABORT
    7. (older-required only) Write to ``<install_dir>/adingest.tmp``;
       ``chmod +x``
    8. (older-required only) Atomic :func:`os.replace` to target;
       update ``<install_dir>/VERSION``
    9. (older-required only) Print success; exit 0

    The class is dependency-injectable for tests: ``install_dir`` parameterizes
    the filesystem operations (use ``tmp_path`` in tests); the manifest fetch
    and bytes fetch each use a dedicated :class:`httpx.Client` so tests can
    inject :class:`httpx.MockTransport` via the ``manifest_transport`` and
    ``bytes_transport`` parameters.
    """

    def __init__(
        self,
        config: AdingestConfig,
        install_dir: Path | None = None,
        manifest_transport: httpx.BaseTransport | None = None,
        bytes_transport: httpx.BaseTransport | None = None,
    ) -> None:
        # Path.home() / ".local" / "share" / "adingest" is functionally
        # identical to Path("~/.local/share/adingest").expanduser() but
        # doesn't depend on the ~ shell-style expansion mid-program.
        self.config = config
        self.install_dir: Path = (
            install_dir if install_dir is not None
            else Path.home() / ".local" / "share" / "adingest"
        )
        self._manifest_transport = manifest_transport
        self._bytes_transport = bytes_transport

    # --- Step 2: fetch manifest --------------------------------------------

    def fetch_manifest(self) -> CliVersionManifest:
        """``GET /v1/cli/version`` with Bearer; parse into the dataclass."""
        client = httpx.Client(
            base_url=self.config.url,
            headers={"Authorization": f"Bearer {self.config.token}"},
            timeout=30.0,
            transport=self._manifest_transport,
        )
        try:
            try:
                resp = client.get("/v1/cli/version")
                resp.raise_for_status()
            except httpx.HTTPStatusError as e:
                raise click.ClickException(
                    f"HTTP {e.response.status_code} GET /v1/cli/version "
                    f"(is the service running at {self.config.url}?)"
                ) from None
            except httpx.RequestError as e:
                raise click.ClickException(
                    f"network error {type(e).__name__}: {e} "
                    f"(is the service running at {self.config.url}?)"
                ) from None
            try:
                body = resp.json()
            except (json.JSONDecodeError, ValueError) as e:
                raise click.ClickException(
                    f"manifest response was not valid JSON: {e}"
                ) from None
            return CliVersionManifest.parse(body)
        finally:
            client.close()

    # --- Step 3: product check ---------------------------------------------

    def check_product(self, manifest: CliVersionManifest) -> None:
        """Refuse upgrade when ``manifest.product != PRODUCT`` (bundled literal)."""
        if manifest.product != PRODUCT:
            raise click.ClickException(
                f"manifest.product={manifest.product!r} != bundled "
                f"PRODUCT={PRODUCT!r}; refusing to upgrade "
                f"(operator pointed CLI at the wrong product's server)"
            )

    # --- Step 4: verdict ---------------------------------------------------

    def compute_verdict(self, manifest: CliVersionManifest) -> UpgradeVerdict:
        """Compare local ``__version__`` to ``manifest.cli_recommended``.

        Four branches:

        - **equal**: local == recommended → "Already at X.Y.Z"
        - **local-newer**: local > recommended → "Server expects X.Y.Z"
        - **older-compatible**: local < recommended AND local >= min_compatible →
          informational nag; current still works
        - **older-required**: local < min_compatible → proceeds to steps 5-9
        """
        local = _version_tuple(__version__)
        recommended = _version_tuple(manifest.cli_recommended)
        floor = _version_tuple(manifest.cli_min_compatible)
        if local == recommended:
            return "equal"
        if local > recommended:
            return "local-newer"
        # local < recommended below.
        if local >= floor:
            return "older-compatible"
        return "older-required"

    # --- Step 5: fetch bytes -----------------------------------------------

    def fetch_bytes(self, download_url: str) -> bytes:
        """``GET`` the stamped CLI bytes from GitHub raw (no Bearer; public)."""
        client = httpx.Client(
            timeout=30.0,
            follow_redirects=True,
            transport=self._bytes_transport,
        )
        try:
            try:
                resp = client.get(download_url)
                resp.raise_for_status()
            except httpx.HTTPStatusError as e:
                raise click.ClickException(
                    f"HTTP {e.response.status_code} GET {download_url} "
                    f"(commit-SHA-pinned URL — pre-bootstrap or mirror tag missing?)"
                ) from None
            except httpx.RequestError as e:
                raise click.ClickException(
                    f"network error {type(e).__name__}: {e} "
                    f"(fetching CLI bytes from {download_url})"
                ) from None
            return resp.content
        finally:
            client.close()

    # --- Step 6: sha256 verify ---------------------------------------------

    def verify_sha256(self, body: bytes, expected_hex: str) -> None:
        """Refuse to install bytes that don't match the manifest's sha256."""
        actual = hashlib.sha256(body).hexdigest()
        if actual != expected_hex:
            raise click.ClickException(
                f"sha256 mismatch: expected {expected_hex!r}, got {actual!r} "
                f"(transport corruption OR mirror tampering — refusing to install)"
            )

    # --- Steps 7-8: atomic replace + VERSION update ------------------------

    def atomic_replace(self, body: bytes, target_version: str) -> None:
        """Write to ``adingest.tmp``, ``chmod +x``, then atomic rename.

        Also updates ``<install_dir>/VERSION`` to ``target_version``. Both
        files live in ``install_dir`` (same filesystem) so :func:`os.replace`
        is POSIX-atomic.
        """
        self.install_dir.mkdir(parents=True, exist_ok=True)
        target = self.install_dir / "adingest"
        tmp = self.install_dir / "adingest.tmp"
        tmp.write_bytes(body)
        # chmod +x (0o755 = rwxr-xr-x); use os.chmod for stable POSIX semantics.
        os.chmod(tmp, 0o755)
        os.replace(tmp, target)
        (self.install_dir / "VERSION").write_text(target_version + "\n")

    # --- Step 1 + 9: orchestrate end-to-end --------------------------------

    def run(self) -> None:
        """Drive the 9-step flow; emit human-readable status per step."""
        # Step 1 is implicit — config.url comes from env or --url override
        # via _build_config; resolving the server is just reading config.url.
        click.echo(f"Resolving server at {self.config.url}...")
        # Step 2: fetch manifest.
        manifest = self.fetch_manifest()
        # Step 3: product check.
        self.check_product(manifest)
        # Step 4: verdict.
        verdict = self.compute_verdict(manifest)
        if verdict == "equal":
            click.echo(f"Already at {__version__}")
            return
        if verdict == "local-newer":
            click.echo(
                f"Server expects {manifest.cli_recommended} (local {__version__})"
            )
            return
        if verdict == "older-compatible":
            click.echo(
                f"Upgrade available: {__version__} -> {manifest.cli_recommended}; "
                f"current works (floor={manifest.cli_min_compatible})"
            )
            return
        # older-required → proceed to steps 5-9.
        click.echo(
            f"Required upgrade: {__version__} -> {manifest.cli_recommended} "
            f"(below floor {manifest.cli_min_compatible})"
        )
        # Step 5: fetch bytes.
        click.echo(f"Fetching {manifest.download_url}...")
        body = self.fetch_bytes(manifest.download_url)
        # Step 6: sha256 verify.
        self.verify_sha256(body, manifest.cli_sha256)
        click.echo(f"sha256 verified ({manifest.cli_sha256[:12]}...)")
        # Steps 7-8: atomic replace + VERSION.
        self.atomic_replace(body, manifest.cli_recommended)
        # Step 9: success.
        click.echo(
            f"Upgraded {__version__} -> {manifest.cli_recommended} "
            f"(installed at {self.install_dir / 'adingest'})"
        )


