def _build_config(
    project: str | None,
    url: str | None,
    token: str | None,
    apps_file: str | None,
) -> AdingestConfig:
    """Build an ``AdingestConfig`` from the active project's TOML + flag overrides.

    Step 9 of core-cli-config-refactor: replaces the legacy
    ``_load_env_client`` → ``AdingestConfig.from_env`` env-var pipeline with
    the TOML-backed cascade.

    Pipeline:

    1. ``resolve_active_project(explicit=project)`` — pick the slug via the
       Step-5 cascade (``--project`` flag → ``$ADINGEST_PROJECT`` env →
       ``state.toml`` → loud failure)
    2. ``_source_project_env(slug)`` — source ``~/.adingest/<slug>/.env`` into
       ``os.environ`` (setdefault; shell wins) so the per-caller TOML's
       ``${VAR}`` references resolve during interpolation
    3. ``load_config(slug)`` — read global + per-caller TOML, deep-merge,
       interpolate ``${VAR}``, translate to ``AdingestConfig``
    4. Apply ``--url`` / ``--token`` / ``--apps`` flag overrides via
       ``dataclasses.replace`` on the frozen dataclass

    Args:
        project: ``--project <slug>`` flag value (highest cascade precedence),
            or ``None`` when the flag isn't supplied.
        url: ``--url`` override; takes final precedence over TOML's
            ``[ingest_api].url``.
        token: ``--token`` override; takes final precedence over TOML's
            ``[ingest_api].token``.
        apps_file: ``--apps <path>`` override; reads a JSON file and replaces
            the TOML-derived ``apps`` list wholesale (legacy ``APPS_JSON`` env
            shape is gone — operators use the TOML ``[[apps]]`` form or this
            override path).

    Returns:
        A new ``AdingestConfig`` instance with overrides applied (or the
        loader's output unchanged when no overrides are supplied).

    Raises:
        click.ClickException: When the cascade can't resolve an active
            project (no flag, no env, no ``state.toml``) — message names
            both recovery paths. Also propagates loader errors (missing
            per-caller ``config.toml``, malformed TOML, missing ``${VAR}``).
    """
    # Read ``ADINGEST_HOME`` fresh at call time so test ``monkeypatch.setattr``
    # on the module constant takes effect; ``resolve_active_project`` /
    # ``_source_project_env`` / ``load_config`` would otherwise bind to the
    # default-arg value captured at function-DEFINITION time. Mirrors the
    # walkup commands' fresh-read pattern (Step 6: ``projects`` / ``current``).
    home = ADINGEST_HOME
    slug = resolve_active_project(explicit=project, home=home)
    _source_project_env(slug, home=home)
    cfg = load_config(slug, home=home)
    overrides: dict[str, Any] = {}
    if url:
        overrides["url"] = url
    if token:
        overrides["token"] = token
    if apps_file:
        overrides["apps"] = json.loads(Path(apps_file).read_text())
    return replace(cfg, **overrides) if overrides else cfg


def _resolve_source(source: str | None, stub: bool) -> str:
    if stub and source and source != "stub":
        raise click.UsageError("--stub and --source are mutually exclusive")
    return "stub" if stub else (source or "levelplay")


def _iter_dates(start: date, end: date) -> Iterator[date]:
    cur = start
    while cur <= end:
        yield cur
        cur = cur + timedelta(days=1)


def _emit(
    response: dict[str, Any], as_json: bool, quiet: bool,
    device_names: list[str] | None = None,
) -> None:
    if as_json:
        # The raw ``--json`` envelope has no roster surface — it already carries
        # ``rows_skipped_test_device`` per source (the server counter flows
        # through the deep-copy untouched). ``device_names`` is human-mode only.
        click.echo(json.dumps(_merge_verdicts_into_response(response)))
        return
    if not quiet:
        # Force a wide console: rich's default 80-col falls back when stdout is
        # not a TTY, which truncates the verdict column under CliRunner / pipes.
        TableRenderer(Console(width=160)).render(response, device_names)


def _flatten_fetch_only_rows(response: dict[str, Any]) -> list[dict[str, Any]]:
    """Concatenate every source's rows from ``rows_by_source`` into one array.

    Reads ``rows_by_source`` DEFENSIVELY (``... or {}``): on an all-source-fail
    ``failed`` job the fetch-only branch never ran, so the wire body carries NO
    ``rows_by_source`` key (the server's omission serializer pops it) — the
    flatten must emit ``[]``, never ``KeyError``. Rows self-describe via their
    ``source`` field, so concatenating across sources is lossless.
    """
    rows_by_source = response.get("rows_by_source") or {}
    flat: list[dict[str, Any]] = []
    for rows in rows_by_source.values():
        flat.extend(rows)
    return flat


def _emit_fetch_only(
    response: dict[str, Any], as_json: bool, quiet: bool,
    device_names: list[str] | None = None,
) -> None:
    """Emit a terminal fetch-only job: bare rows → stdout, counters → stderr.

    ``--json``: the flattened rows array (``json.dumps``) is written to STDOUT as
    the sole rows surface; the counters envelope — the same verdict-merged JSON
    ``ingest --json`` emits, but with ``rows_by_source`` and ``fetch_only``
    popped — is written to STDERR. ``--json --quiet`` suppresses the stderr
    envelope entirely (byte-clean empty stderr; the exit code is the only
    failure signal in that mode).

    Ordering interlock (guards the Step 6 mode-aware classifier):
    ``_merge_verdicts_into_response`` runs on the FULL response FIRST — once the
    classifier lands it reads the top-level ``fetch_only`` flag off that response
    to pick the trigger set — and only THEN are ``fetch_only``/``rows_by_source``
    popped from the RETURNED envelope. Popping ``fetch_only`` before the merge
    would make the classifier mode-blind and resurrect the ``silent-drop`` false
    positive on this exact ``2>counters.json`` channel. The ``rows_by_source``
    pop is also load-bearing for payload size: the merge deep-copies the whole
    response, so leaving the key in would duplicate the entire rows array inside
    the stderr envelope.

    Human (non-``--json``) mode renders the fetch-only summary: per-source
    counters (fetched / invalid / verdict) plus a per-(platform, app_id) row
    breakdown counted from the returned rows. Writer-boundary columns and the
    GA4 line are omitted (fetch-only touches neither); no raw rows are dumped.
    """
    if as_json:
        click.echo(json.dumps(_flatten_fetch_only_rows(response)))
        if not quiet:
            envelope = _merge_verdicts_into_response(response)
            envelope.pop("rows_by_source", None)
            envelope.pop("fetch_only", None)
            # ``rows_skipped_test_device`` rides the stderr envelope per source
            # (server counter, carried through the deep-copy). No roster on the
            # raw ``--json`` channel — ``device_names`` is human-mode only.
            click.echo(json.dumps(envelope), err=True)
        return
    if not quiet:
        TableRenderer(Console(width=160)).render_fetch_only(response, device_names)


def _common(f: Any) -> Any:
    """Shared option decorator for data-touching commands.

    Step 9 of core-cli-config-refactor: ``--project`` lands as the first
    option per R1 LOW#5 (Item 4) — Click renders options in decoration order,
    and ``--project`` is the highest-precedence cascade tier so listing it
    first matches the conceptual hierarchy in ``--help`` output. The flag's
    value is threaded into ``_build_config(project=...)`` by each command
    body, where it becomes the ``explicit`` argument to
    ``resolve_active_project``.
    """
    for opt in reversed((
        click.option(
            "--project", default=None,
            help="Override active project (default: from state.toml or ADINGEST_PROJECT env)",
        ),
        click.option("--url", default=None, help="Override INGEST_API_URL"),
        click.option("--token", default=None, help="Override INGEST_API_TOKEN"),
        click.option("--json", "as_json", is_flag=True, help="Emit raw JSON (with verdicts)"),
        click.option("--quiet", is_flag=True, help="Suppress non-verdict output"),
    )):
        f = opt(f)
    return f


@click.group(name="adingest")
@click.version_option(__version__, "--version")
def cli() -> None:
    """adingest — project-agnostic CLI for the ad-ingest service."""


@cli.command()
@click.argument("event_date")
@click.option("--poll", is_flag=True, help="Poll until job is terminal")
@click.option("--source", default=None, help="Source name (default: levelplay)")
@click.option("--stub", is_flag=True, help="Alias for --source stub")
@click.option("--apps", "apps_file", default=None, type=click.Path(exists=True),
              help="JSON file with apps[]")
@_common
def ingest(event_date: str, poll: bool, source: str | None, stub: bool, apps_file: str | None,
           project: str | None, url: str | None, token: str | None,
           as_json: bool, quiet: bool) -> None:
    """POST one ingest for EVENT_DATE (YYYY-MM-DD)."""
    cfg = _build_config(project, url, token, apps_file)
    client = AdingestClient(cfg)
    resp = client.post_ingest(event_date, _resolve_source(source, stub), cfg.apps)
    if poll and resp.get("job_id"):
        resp = client.poll_until_terminal(resp["job_id"])
    _emit(resp, as_json, quiet, [d.name for d in cfg.test_devices])


@cli.command(name="fetch-only")
@click.argument("event_date")
@click.option("--source", default=None, help="Source name (default: levelplay)")
@click.option("--stub", is_flag=True, help="Alias for --source stub")
@click.option("--apps", "apps_file", default=None, type=click.Path(exists=True),
              help="JSON file with apps[]")
@_common
def fetch_only(
    event_date: str, source: str | None, stub: bool, apps_file: str | None,
    project: str | None, url: str | None, token: str | None,
    as_json: bool, quiet: bool,
) -> None:
    """Fetch EVENT_DATE (YYYY-MM-DD) rows without writing; pipe them to stdout.

    Runs the identical adapter fetch → validation → match-remap path as
    ``ingest`` but STOPS before every sink (no BQ write, no dedup query, no GA4
    fan-out), returning the day's canonical revenue rows. Requires only source
    creds + a bearer — no destination credentials.

    Always polls to a terminal state (no ``--poll`` flag). With ``--json``, the
    bare rows array lands on STDOUT (pipeable into ``jq``/files) and the counters
    envelope on STDERR; ``--json --quiet`` gives byte-clean stdout with empty
    stderr. Without ``--json``, prints a human counters summary and no rows dump.

    Exit code: 0 on ``complete`` (an empty day is ``[]`` + exit 0); non-zero on
    ``partial`` (surviving sources' rows still emitted to stdout), ``failed``, or
    a non-terminal poll timeout.
    """
    try:
        date.fromisoformat(event_date)
    except ValueError:
        raise click.UsageError(
            "fetch-only takes a single date; use `range` for spans"
        ) from None
    cfg = _build_config(project, url, token, apps_file)
    client = AdingestClient(cfg)
    resp = client.post_fetch_only(event_date, _resolve_source(source, stub), cfg.apps)
    if resp.get("job_id"):
        resp = client.poll_until_terminal(resp["job_id"])
    _emit_fetch_only(resp, as_json, quiet, [d.name for d in cfg.test_devices])
    # Strict exit: only a terminal ``complete`` is success. ``partial`` /
    # ``failed`` / a non-terminal poll-timeout body all exit non-zero — the
    # rows (or ``[]``) have already been emitted above, so a partial run still
    # pipes its surviving rows before the alarm fires.
    if resp.get("status") != "complete":
        sys.exit(1)


@cli.command(name="range")
@click.argument("date_range")
@click.option("--poll", is_flag=True, help="Poll each job until terminal")
@click.option("--source", default=None, help="Source name (default: levelplay)")
@click.option("--stub", is_flag=True, help="Alias for --source stub")
@click.option("--apps", "apps_file", default=None, type=click.Path(exists=True),
              help="JSON file with apps[]")
@click.option("--continue-on-failure", is_flag=True, help="Do not abort on first failure")
@_common
def range_cmd(
    date_range: str, poll: bool, source: str | None, stub: bool, apps_file: str | None,
    continue_on_failure: bool, project: str | None, url: str | None, token: str | None,
    as_json: bool, quiet: bool,
) -> None:
    """Fire one ingest per day in START..END (inclusive)."""
    if ".." not in date_range:
        raise click.UsageError("date range must be in form START..END")
    start_s, _, end_s = date_range.partition("..")
    start, end = date.fromisoformat(start_s), date.fromisoformat(end_s)
    if end < start:
        raise click.UsageError("END date must be >= START date")
    cfg = _build_config(project, url, token, apps_file)
    src = _resolve_source(source, stub)
    client = AdingestClient(cfg)
    for day in _iter_dates(start, end):
        resp = client.post_ingest(day.isoformat(), src, cfg.apps)
        if poll and resp.get("job_id"):
            resp = client.poll_until_terminal(resp["job_id"])
        _emit(resp, as_json, quiet, [d.name for d in cfg.test_devices])
        if resp.get("status") == "failed" and not continue_on_failure:
            sys.exit(1)


@cli.command()
@click.argument("job_id")
@_common
def status(job_id: str, project: str | None, url: str | None, token: str | None,
           as_json: bool, quiet: bool) -> None:
    """GET status for JOB_ID."""
    cfg = _build_config(project, url, token, None)
    resp = AdingestClient(cfg).get_job(job_id)
    _emit(resp, as_json, quiet, [d.name for d in cfg.test_devices])


@cli.command()
@click.option("--project", default=None, help="Override active project")
@click.option("--url", default=None, help="Override INGEST_API_URL")
@click.option("--token", default=None, help="Override INGEST_API_TOKEN")
def upgrade(project: str | None, url: str | None, token: str | None) -> None:
    """Upgrade the installed CLI via the service manifest + GitHub mirror.

    Drives the 9-step universal upgrade flow (see :class:`UpgradeFlow`):
    fetches ``/v1/cli/version`` manifest, verifies product identity, computes
    a verdict, and (for older-required) fetches commit-SHA-pinned bytes from
    the public mirror, sha256-verifies, and atomically replaces the installed
    copy.

    Same code path works against any substrate (localhost uvicorn today,
    AWS App Runner tomorrow) because the manifest contract is wire-stable.

    Step 10 of core-cli-config-refactor: ``upgrade`` uses INLINE decorators
    (NOT the shared ``_common`` decorator that ``ingest`` / ``range`` /
    ``status`` use), so ``--project`` is added here as its own
    ``@click.option`` rather than inherited. The flag is threaded through
    ``_build_config(project, url, token, None)`` to the same 4-arg signature
    Step 9 established; the manifest URL is then resolved from the selected
    project's ``[ingest_api].url`` (per-caller TOML overlay over global —
    so a staging project can point at a staging manifest endpoint without
    disturbing the production cron's manifest source).
    """
    cfg = _build_config(project, url, token, None)
    flow = UpgradeFlow(cfg)
    flow.run()


# --- Walkup commands: projects / use / current -----------------------------
#
# Step 6 of core-cli-config-refactor. First operator-facing surface change of
# the refactor. Three read/write commands operating on ``~/.adingest/``:
#
#   * ``projects`` (ls)  — list configured callers; mark active with ``*``
#   * ``use <slug>`` (cd) — set active caller (writes ``state.toml`` atomically)
#   * ``current`` (pwd)   — print the active caller's slug
#
# All three commands use the Step-5 cascade (``resolve_active_project``) as the
# single source of truth for "which slug is active right now" — so env / state
# precedence is consistent across the walkup quartet AND the data-touching
# commands rewritten in Step 9 (``ingest`` / ``range`` / ``status`` / ``upgrade``).
#
# Important: ``projects`` calls ``resolve_active_project()`` purely to compute
# the ``*`` active-marker — and narrows the resulting ``ClickException`` catch
# to ONLY the "no active project" sentinel string. Any OTHER ClickException
# (e.g., the malformed-``state.toml`` raise from ``_read_state_active`` per R1
# MED#1) re-propagates loudly. Catching ``ClickException`` broadly would
# silently swallow the data-corruption signal — the opposite of the loud-failure
# contract Step 4 established.


@cli.command()
def projects() -> None:
    """List configured callers under ``~/.adingest/``; mark the active one with ``*``.

    Scans ``~/.adingest/*/config.toml`` and prints each slug on its own line,
    sorted alphabetically. The active slug (per the Step-5 cascade —
    ``$ADINGEST_PROJECT`` env > ``state.toml`` active) is prefixed with ``*``;
    non-active slugs get a leading space for column alignment.

    Errors loudly if no projects are configured (``~/.adingest/`` doesn't
    exist OR contains zero ``<slug>/config.toml`` files), naming the
    ``adingest init <slug>`` bootstrap command in the message.

    Active-marker resolution uses ``resolve_active_project()`` rather than a
    parallel ``state.toml`` read so this command and the data-touching commands
    share one source of truth for "which slug is active." If the cascade itself
    fails with "no active project" (no flag, no env, no ``state.toml``), the
    list still renders — no slug gets the ``*`` marker. Any OTHER cascade
    failure (e.g., malformed ``state.toml``) re-raises loudly so the operator
    sees the corruption signal.
    """
    home = ADINGEST_HOME
    # Empty home: doesn't exist OR exists with zero <slug>/config.toml files.
    if not home.exists():
        raise click.ClickException(
            f"no projects configured at {home}; "
            f"run `adingest init <slug>` to bootstrap"
        )
    slugs = sorted(
        d.name
        for d in home.iterdir()
        if d.is_dir() and (d / "config.toml").exists()
    )
    if not slugs:
        raise click.ClickException(
            f"no projects configured at {home}; "
            f"run `adingest init <slug>` to bootstrap"
        )

    # Resolve active via the cascade (single source of truth). Narrow the
    # catch: only the "no active project" sentinel is swallowed — any other
    # ClickException (e.g., malformed state.toml) re-propagates. Broadening
    # the catch would silently swallow the corruption signal that Step 4's
    # loud-failure contract in ``_read_state_active`` establishes.
    #
    # ``home=home`` is passed explicitly (not relying on the function's
    # default-arg binding) because Python evaluates default-args at function
    # DEFINITION time. The module-level ``ADINGEST_HOME`` constant can be
    # patched at runtime (tests via ``monkeypatch.setattr``); reading the
    # module attribute inside the command body picks up the patched value,
    # but the called helper would otherwise see its frozen default.
    try:
        active: str | None = resolve_active_project(home=home)
    except click.ClickException as e:
        if "no active project" in str(e):
            active = None
        else:
            raise

    for slug in slugs:
        marker = "*" if slug == active else " "
        click.echo(f"{marker} {slug}")


@cli.command()
@click.argument("slug")
def use(slug: str) -> None:
    """Set the active caller to ``SLUG`` (writes ``~/.adingest/state.toml``).

    Validates the slug shape (alphanumeric + interior hyphens), verifies that
    ``~/.adingest/<slug>/config.toml`` exists (refuses to point ``state.toml``
    at an uninitialized caller), then writes the new active pointer
    atomically via ``write_state_active`` (POSIX-atomic ``os.replace`` per
    Step 4).

    Echoes the new active slug. When the prior active was a different slug,
    the echo carries a ``(was: <prior>)`` suffix so the operator sees the
    transition; re-``use``-ing an already-active slug omits the suffix
    (the prior == new case is silent on prior per the design's line 397 contract).
    """
    _validate_slug(slug)
    # Read ``ADINGEST_HOME`` fresh at call time so test ``monkeypatch.setattr``
    # is honored — default-arg binding of helpers is frozen at definition time,
    # so all calls below pass ``home=home`` explicitly.
    home = ADINGEST_HOME
    if not (home / slug / "config.toml").exists():
        raise click.ClickException(
            f"project {slug!r} not initialized "
            f"(no {home / slug / 'config.toml'}; "
            f"run `adingest init {slug}` first)"
        )

    # Read prior active silently — ``_read_state_active`` returns None on
    # absent state.toml AND raises loudly on malformed. We let the raise
    # propagate (corruption signal); None just suppresses the (was: ...)
    # suffix below.
    prior = _read_state_active(home)
    write_state_active(slug, home=home)

    if prior and prior != slug:
        click.echo(f"Active project: {slug}  (was: {prior})")
    else:
        click.echo(f"Active project: {slug}")


@cli.command()
def current() -> None:
    """Print the active caller's slug (cascade-resolved).

    Resolves via the standard cascade: ``--project`` flag (not applicable
    here — ``current`` doesn't take ``--project``) → ``$ADINGEST_PROJECT``
    env → ``~/.adingest/state.toml`` active → error.

    Raises loudly with the exact remediation message when no caller is
    active (the cascade's tier-4 ``ClickException``). The error message
    names both recovery paths (``adingest use <slug>`` for persistent
    default, ``--project <slug>`` for per-invocation override) AND points
    at ``adingest projects`` for the list of configured slugs.
    """
    # Pass ``home=ADINGEST_HOME`` explicitly so the (potentially patched)
    # module-level constant flows through — default-arg binding is frozen
    # at function definition time and would otherwise bypass test overrides.
    click.echo(resolve_active_project(home=ADINGEST_HOME))


# --- Walkup command: init ---------------------------------------------------
#
# Step 7 of core-cli-config-refactor. Completes the walkup quartet by
# bootstrapping a new caller dir under ``~/.adingest/<slug>/`` with a
# template ``config.toml`` (``${VAR}`` placeholders for secrets, blank
# strings for structural fields the operator must fill) + an empty,
# mode-0600 ``.env`` scaffold + auto-activate if no current active.
#
# ``init <slug>`` scaffolds a template caller dir (the legacy
# ``--from-env-client`` migration branch was retired with ``.env.client`` on
# 2026-06-22).
#
# Auto-activate (per E2 H1): if ``state.toml`` has no
# active slug (``_read_state_active`` returns None), this step's ``init``
# writes ``state.toml`` so the just-created slug becomes the active one.
# Subsequent ``init`` calls (when an active is already set) do NOT change
# state.toml — the operator picks the active slug deliberately via ``use``.
#
# The template ``config.toml`` is intentionally MINIMAL — it carries the
# structural sections (``[ingest_api]``, ``[levelplay]``, ``[bq]``) with
# ``${VAR}`` placeholders for the secret fields the migration branch
# (Step 11) will reference. The ``[[apps]]`` block is NOT pre-populated
# (init has no knowledge of which apps the caller will host); a commented
# stub at the end of the file points the operator at the goal-doc for the
# per-app shape.


def _write_template_config(target_dir: Path, slug: str) -> None:
    """Write a template ``config.toml`` + empty ``.env`` to ``target_dir``.

    Materializes the per-caller scaffolding for ``adingest init <slug>``'s
    bare-template branch. The ``config.toml`` carries the three structural
    sections (``[ingest_api]``, ``[levelplay]``, ``[bq]``) with ``${VAR}``
    placeholders for the secret fields (``LP_SECRET_KEY``,
    ``LP_REFRESH_TOKEN``); structural fields
    (``url``, ``project_id``, ``dataset``, ``sa_key_path``) are blank
    strings the operator fills via editor. A commented stub at the end of
    the file directs the operator at the goal-doc's "What the operator
    actually edits" section for the per-app ``[[apps]]`` shape.

    The companion ``.env`` is empty except for commented secret-var hints
    (``# LP_SECRET_KEY=`` etc.) so the operator sees the var names they're
    expected to fill in but no real values leak as defaults. Mode 0600
    chmod is applied AFTER the atomic write — keeps test parity with the
    migration branch (Step 11) which also lands at 0600.

    Both writes go through ``_atomic_write_text`` (Step 4 helper) so the
    durability contract is uniform across template and migration branches.
    The ``[[apps]]`` stub comment is appended to the dumped TOML string as
    a raw line — ``tomli_w`` does not preserve standalone comments through
    dict → string serialization.

    Args:
        target_dir: Per-caller directory (``~/.adingest/<slug>/``). Caller
            (the ``init`` command body) creates this directory before
            invoking this helper.
        slug: Validated project slug. Used in the file-header comment so
            the operator sees which caller this file is for when opening
            it in an editor.
    """
    skeleton: dict[str, Any] = {
        "ingest_api": {
            "url": "",
            "token": "",
        },
        "levelplay": {
            "secret_key": "${LP_SECRET_KEY}",
            "refresh_token": "${LP_REFRESH_TOKEN}",
        },
        "bq": {
            "project_id": "",
            "dataset": "",
            "sa_key_path": "",
        },
    }

    apps_stub_comment = (
        "\n"
        "# [[apps]] — add per-app blocks here; see "
        'docs/core-cli-config-refactor-goal.md "What the operator actually edits" '
        "for the per-app shape\n"
    )

    config_payload = (
        f"# ~/.adingest/{slug}/config.toml\n"
        f"# Per-caller config for {slug}; fill blank fields via editor.\n"
        f"# Secrets stay in ~/.adingest/{slug}/.env (mode 0600); this file\n"
        f"# references them via ${{VAR}} interpolation at CLI startup.\n"
        f"\n"
        + tomli_w.dumps(skeleton)
        + apps_stub_comment
    )

    _atomic_write_text(target_dir / "config.toml", config_payload, target_dir)

    # ``.env`` scaffold — secret var names commented out so the operator
    # sees what's expected but no defaults leak. Mode 0600 set after
    # write (``_atomic_write_text`` writes via os.open with mode 0o644).
    env_payload = (
        f"# ~/.adingest/{slug}/.env  (mode 0600 — CLI warns on looser perms)\n"
        f"# Fill these in with the real values; CLI auto-sources at startup.\n"
        f"\n"
        f"# INGEST_API_TOKEN=...\n"
        f"# LP_SECRET_KEY=...\n"
        f"# LP_REFRESH_TOKEN=...\n"
        f"# GA4_API_SECRET=...\n"
    )

    env_path = target_dir / ".env"
    _atomic_write_text(env_path, env_payload, target_dir)
    os.chmod(env_path, 0o600)


@cli.command()
@click.argument("slug")
def init(slug: str) -> None:
    """Bootstrap ``~/.adingest/<slug>/`` with a template config + empty .env.

    Creates the per-caller directory and writes a template ``config.toml``
    (``${VAR}`` placeholders for secrets; blank structural fields the
    operator fills via editor) plus an empty, mode-0600 ``.env`` scaffold.

    Auto-activate: if ``state.toml`` has no active slug after the
    materialization, this command also writes ``state.toml`` so the
    just-created slug becomes the active one. Subsequent ``init`` calls
    (when an active is already set) do NOT change state.toml — operators
    pick the active slug deliberately via ``adingest use``.

    Refuses to overwrite an existing ``~/.adingest/<slug>/`` directory;
    the operator must remove it manually if re-init is intended.

    (The legacy ``--from-env-client`` migration flag was retired with
    ``.env.client`` on 2026-06-22 — populate the scaffolded ``config.toml`` +
    ``.env`` directly.)
    """
    _validate_slug(slug)

    # Read ``ADINGEST_HOME`` fresh at call time so test ``monkeypatch.setattr``
    # is honored — default-arg binding of helpers is frozen at definition
    # time, so all calls below pass ``home=home`` explicitly.
    home = ADINGEST_HOME
    target_dir = home / slug

    if target_dir.exists():
        raise click.ClickException(
            f"{target_dir} already exists; refusing to overwrite "
            f"(remove it manually and re-run init)"
        )

    target_dir.mkdir(parents=True)

    _write_template_config(target_dir, slug)

    # Auto-activate (per E2 H1): only when no current active. ``init``
    # bootstrapping the very first caller should leave the operator with
    # a usable ``adingest`` invocation without needing a separate
    # ``adingest use``. Subsequent ``init`` calls (when an active is
    # already set) preserve the operator's deliberate choice.
    if _read_state_active(home) is None:
        write_state_active(slug, home=home)
        click.echo(f"Active project: {slug}")


# --- `config` subgroup: `config show` --------------------------------------
#
# Step 8 of core-cli-config-refactor. Subgroup container per R1 MED#4 — keeps
# future ``config edit`` / ``config path`` / ``config validate`` extensible
# without re-architecting from ``@cli.command`` to ``@cli.group`` later.
#
# ``config show`` is the inspection surface for the caller config — resolves
# the active project via the standard cascade (``--project`` override
# honored), sources the per-caller ``.env`` (so ``${VAR}`` references inside
# ``config.toml`` resolve through ``os.environ``), invokes ``load_config``,
# and renders the resulting frozen :class:`AdingestConfig` as a rich Table.
#
# Output policy (per Open Question #2 in the design doc): secrets render
# LITERAL, not redacted. Operators run ``config show`` to debug, and a
# ``****`` mask would defeat the purpose; the file lives at mode 0600 under
# ``~/.adingest/<slug>/.env`` and the operator is the only viewer.
#
# Apps list rendering (per Step 8 Specification + design Item 3): the
# ``apps`` field is a list of dicts (each app's TOML structure carried
# through verbatim per D14). Every leaf in every app dict gets its own
# row with dot-notation key path — ``apps[0].app_id``, ``apps[0].ga4.api_secret``,
# etc. No collapsing, no summarization — matches the no-redaction stance
# from Open Question #2.
#
# Cache short-circuit interaction: Step 5's ``_ACTIVE_PROJECT_CACHE`` is a
# process-lifetime cache. Each CLI invocation is a fresh process, so the
# cache is always cold when ``config_show`` enters — ``explicit=project``
# always wins. Tests that reuse the in-process module (CliRunner) must
# call ``_invalidate_cache_for_tests()`` between invocations; the autouse
# ``_reset_cache_between_tests`` fixture in ``test_core_cli_walkup.py``
# handles this until Step 14 lifts it to conftest scope.


@cli.group(name="config")
def config_grp() -> None:
    """Inspect/manage caller config under ``~/.adingest/``."""


def _render_config_table(cfg: AdingestConfig) -> None:
    """Render an :class:`AdingestConfig` to stdout as a rich ``Table``.

    Two columns: ``Key`` (dot-notation path) and ``Value`` (literal resolved
    value — secrets NOT redacted per Open Question #2 in the design doc).
    Every dataclass field gets a row; the ``apps`` list nests one row per
    leaf using ``apps[i].<key>`` (and ``apps[i].ga4.<key>`` for the nested
    sub-table) path notation per design Item 3.

    The renderer writes to a fresh :class:`Console` so output goes to
    ``sys.stdout``; tests capture via ``CliRunner.invoke``'s output channel.

    Args:
        cfg: The validated config to render. Field order follows the
            dataclass declaration order; ``apps`` is always rendered last.
    """
    from dataclasses import fields as dc_fields

    console = Console()
    table = Table(show_header=True, header_style="bold")
    table.add_column("Key")
    table.add_column("Value")

    apps_field_name = "apps"
    for f in dc_fields(cfg):
        if f.name == apps_field_name:
            continue
        value = getattr(cfg, f.name)
        table.add_row(f.name, str(value))

    # ``apps`` last — nested rows per app and per nested sub-table.
    apps: list[dict[str, Any]] = getattr(cfg, apps_field_name)
    for i, app in enumerate(apps):
        for k, v in app.items():
            if isinstance(v, dict):
                for sub_k, sub_v in v.items():
                    table.add_row(f"apps[{i}].{k}.{sub_k}", str(sub_v))
            else:
                table.add_row(f"apps[{i}].{k}", str(v))

    console.print(table)


@config_grp.command("show")
@click.option(
    "--project",
    default=None,
    help="Override cascade — show config for this slug instead of the active one.",
)
def config_show(project: str | None) -> None:
    """Render the resolved caller config as a rich table.

    Resolves the active slug via the standard cascade (``--project`` →
    ``$ADINGEST_PROJECT`` → ``state.toml`` → error), sources the per-caller
    ``.env``, loads + interpolates ``config.toml``, and renders the
    resulting :class:`AdingestConfig` as a two-column rich Table.

    Secrets are shown LITERAL (no redaction) per Open Question #2 — the
    operator runs ``config show`` to debug and a mask would defeat the
    purpose; secrets live at mode 0600 under ``~/.adingest/<slug>/.env``
    and the operator is the sole viewer.
    """
    home = ADINGEST_HOME
    slug = resolve_active_project(explicit=project, home=home)
    _source_project_env(slug, home=home)
    cfg = load_config(slug, home=home)
    _render_config_table(cfg)


